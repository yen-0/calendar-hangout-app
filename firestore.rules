rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Per-user calendar items (events + stamps): only the owner.
    match /users/{userId}/calendarItems/{itemId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // PRIVATE subtree — refresh tokens and other server-only secrets.
    // Clients must never read or write this; only the Admin SDK has access.
    match /users/{userId}/private/{document=**} {
      allow read, write: if false;
    }

    // Hangout requests: creator can do anything, anyone authenticated can read
    // (so participants can open a shared link) and write their own participant entry.
    // NOTE: tighten in slice 6 if needed (e.g., restrict writes to participant subfield only).
    match /hangoutRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.creatorUid == request.auth.uid;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && resource.data.creatorUid == request.auth.uid;
    }

    // Per-user notifications.
    match /userNotifications/{userId}/notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Shareable stamp packs. Readable by anyone (incl. guests) while not
    // revoked; owners can always read their own (for the "My packs" list, even
    // after revoking). Only the owner can create / update / delete.
    match /stampPacks/{packId} {
      allow read: if resource.data.revokedAt == null
                  || (request.auth != null && request.auth.uid == resource.data.ownerUid);
      allow create: if request.auth != null
                    && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
                            && request.auth.uid == resource.data.ownerUid;
    }
  }
}
